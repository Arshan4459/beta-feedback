# ===== Beta Student Feedback Form — environment =====
# Local dev: copy to `.env.local`. With NOTHING set, the app runs fully locally
# (in-process PGlite DB + local-disk storage) — no infra needed.
# Production: set these in Netlify (web) and on your infra box (worker).

# ---- Client (must keep NEXT_PUBLIC_ prefix) ----
# Submit mode: api | endpoint | download. Defaults to "api" (our backend).
NEXT_PUBLIC_SUBMIT_MODE=api
# Per-clip recording cap, seconds.
NEXT_PUBLIC_MAX_SECONDS=120
# Browser-facing origin of your object storage (for the CSP connect-src so the
# browser can PUT clips). e.g. https://storage.yourdomain.com
NEXT_PUBLIC_S3_PUBLIC_ENDPOINT=
# Legacy external endpoint (only used when NEXT_PUBLIC_SUBMIT_MODE=endpoint).
NEXT_PUBLIC_SUBMIT_ENDPOINT=

# ---- Database (unset locally -> PGlite at ./.pglite) ----
DATABASE_URL=
# Set "false" only for non-TLS Postgres (e.g. inside docker-compose).
DATABASE_SSL=

# ---- Object storage (unset locally -> ./.uploads on disk) ----
# STORAGE_DRIVER is inferred: "s3" if S3_BUCKET is set, else "local".
STORAGE_DRIVER=
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
# Per-clip hard cap in bytes (default 15 MB).
MAX_AUDIO_BYTES=15728640

# ---- Secrets ----
# Salt for hashing student IPs before storage (set a long random value in prod).
IP_HASH_SALT=
# Bearer token for GET /api/export. Export is DISABLED until this is set.
EXPORT_TOKEN=

# ---- Worker / docker-compose only ----
POSTGRES_PASSWORD=change-me
# faster-whisper model: tiny | base | small | medium | large-v3
WHISPER_MODEL=base
